<Window x:Class="XIAOHAI.AI.CompressionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="压缩知识库内容"
        Height="500" Width="600"
        MinHeight="400" MinWidth="500"
        Background="#0a0b0f"
        WindowStartupLocation="CenterOwner"
        Icon="/ziyuan/bitbug_favicon.ico">
    <Window.Resources>
        <SolidColorBrush x:Key="BgDark" Color="#0a0b0f"/>
        <SolidColorBrush x:Key="BgCard" Color="#12141c"/>
        <SolidColorBrush x:Key="Border" Color="#6366f1"/>
        <SolidColorBrush x:Key="Text" Color="#e8eaf0"/>
        <SolidColorBrush x:Key="TextMuted" Color="#8b8fa8"/>
        <SolidColorBrush x:Key="Accent" Color="#6366f1"/>
        <LinearGradientBrush x:Key="AccentGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#6366f1" Offset="0"/>
            <GradientStop Color="#8b5cf6" Offset="1"/>
        </LinearGradientBrush>
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <TextBlock Grid.Row="0" Text="选择压缩级别" FontSize="16" FontWeight="Bold" 
                   Foreground="{StaticResource Text}" Margin="0,0,0,15"/>
        
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,15">
            <RadioButton x:Name="Level1Radio" Content="轻度 (保留关键信息)" 
                         Foreground="{StaticResource Text}" Margin="0,0,20,0" 
                         GroupName="CompressionLevel" IsChecked="True"
                         Checked="CompressionLevel_Changed"/>
            <RadioButton x:Name="Level2Radio" Content="中度 (提取要点)" 
                         Foreground="{StaticResource Text}" Margin="0,0,20,0" 
                         GroupName="CompressionLevel"
                         Checked="CompressionLevel_Changed"/>
            <RadioButton x:Name="Level3Radio" Content="高度 (仅保留摘要)" 
                         Foreground="{StaticResource Text}" 
                         GroupName="CompressionLevel"
                         Checked="CompressionLevel_Changed"/>
        </StackPanel>
        
        <Border Grid.Row="2" Background="{StaticResource BgCard}" 
                BorderBrush="{StaticResource Border}" BorderThickness="1" 
                CornerRadius="8" Padding="10" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0">
                    <TextBlock Text="原始内容" Foreground="{StaticResource TextMuted}" FontSize="12"/>
                    <TextBlock x:Name="OriginalLengthText" Text="0 字符" 
                               Foreground="{StaticResource Text}" FontSize="14" FontWeight="Bold"/>
                </StackPanel>
                
                <TextBlock Grid.Column="1" Text="→" Foreground="{StaticResource Accent}" 
                           FontSize="20" VerticalAlignment="Center" Margin="15,0"/>
                
                <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                    <TextBlock Text="压缩后内容" Foreground="{StaticResource TextMuted}" FontSize="12"/>
                    <TextBlock x:Name="CompressedLengthText" Text="0 字符" 
                               Foreground="#22c55e" FontSize="14" FontWeight="Bold"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <Border Grid.Row="3" Background="{StaticResource BgCard}" 
                BorderBrush="{StaticResource Border}" BorderThickness="1" 
                CornerRadius="8" Margin="0,0,0,15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <Border Grid.Row="0" Background="#1a1b26" Padding="10">
                    <TextBlock x:Name="PreviewTitleText" Text="压缩预览" 
                               Foreground="{StaticResource TextMuted}" FontSize="12"/>
                </Border>
                
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="PreviewText" Text="" 
                               Foreground="{StaticResource Text}" 
                               Padding="10" TextWrapping="Wrap"/>
                </ScrollViewer>
            </Grid>
        </Border>
        
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="CompressBtn" Content="压缩" Width="100" Height="36" Margin="0,0,10,0"
                    Background="{StaticResource AccentGradient}" Foreground="{StaticResource Text}"
                    BorderThickness="0" Cursor="Hand" Click="CompressBtn_Click"/>
            <Button x:Name="CancelBtn" Content="取消" Width="100" Height="36"
                    Background="Transparent" Foreground="{StaticResource Text}"
                    BorderBrush="{StaticResource Border}" BorderThickness="1" Cursor="Hand" Click="CancelBtn_Click"/>
        </StackPanel>
    </Grid>
</Window>
