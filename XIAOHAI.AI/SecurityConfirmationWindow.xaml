<Window x:Class="XIAOHAI.AI.SecurityConfirmationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="安全确认"
        Height="500" Width="600"
        Background="#0a0b0f"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    
    <Window.Resources>
        <SolidColorBrush x:Key="BgDark" Color="#0a0b0f"/>
        <SolidColorBrush x:Key="BgCard" Color="#12141c"/>
        <SolidColorBrush x:Key="Border" Color="#6366f1"/>
        <SolidColorBrush x:Key="Text" Color="#e8eaf0"/>
        <SolidColorBrush x:Key="TextMuted" Color="#8b8fa8"/>
        <SolidColorBrush x:Key="Accent" Color="#6366f1"/>
        <SolidColorBrush x:Key="Warning" Color="#f59e0b"/>
        <SolidColorBrush x:Key="Danger" Color="#ef4444"/>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- 标题 -->
        <Border Grid.Row="0" Background="{StaticResource BgCard}" BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1" Padding="20,16">
            <StackPanel>
                <TextBlock Text="⚠️ 安全警告" Foreground="{StaticResource Warning}" FontWeight="SemiBold" FontSize="18"/>
                <TextBlock Text="检测到脚本中存在潜在风险操作，请仔细审查后再决定是否执行" Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>
        
        <!-- 内容区 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20">
            <StackPanel>
                <!-- 风险列表 -->
                <Border Background="{StaticResource BgCard}" BorderBrush="{StaticResource Warning}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="🔴 检测到的风险：" Foreground="{StaticResource Warning}" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8"/>
                        <ItemsControl x:Name="RisksList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="• " Foreground="{StaticResource Warning}" FontSize="13" Margin="0,2,0,0">
                                        <Run Text="{Binding}" Foreground="{StaticResource Text}"/>
                                    </TextBlock>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
                
                <!-- 脚本功能描述 -->
                <Border Background="{StaticResource BgCard}" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="📋 脚本功能描述：" Foreground="{StaticResource Accent}" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8"/>
                        <TextBlock x:Name="DescriptionText" Text="" Foreground="{StaticResource Text}" FontSize="13" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
                
                <!-- Python 代码预览 -->
                <Border Background="{StaticResource BgCard}" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="8" Padding="16">
                    <StackPanel>
                        <TextBlock Text="💻 Python 代码预览：" Foreground="{StaticResource Text}" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8"/>
                        <Border Background="#1a1c25" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,0,8">
                            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" MaxHeight="200">
                                <TextBlock x:Name="CodePreviewText" Text="" Foreground="{StaticResource TextMuted}" FontSize="11" FontFamily="Consolas" TextWrapping="Wrap"/>
                            </ScrollViewer>
                        </Border>
                        <TextBlock Text="⚠️ 请仔细检查代码，确保没有恶意操作" Foreground="{StaticResource Warning}" FontSize="11" FontStyle="Italic"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
        
        <!-- 按钮区 -->
        <Border Grid.Row="2" Background="{StaticResource BgCard}" BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0" Padding="20,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <CheckBox x:Name="RememberChoiceCheckBox" Grid.Column="0" Content="记住我的选择（不再提示类似风险）" 
                          Foreground="{StaticResource TextMuted}" FontSize="12" VerticalAlignment="Center"/>
                
                <Button x:Name="CancelBtn" Grid.Column="1" Content="取消执行" Width="100" Height="36" Margin="0,0,12,0"
                        Background="Transparent" Foreground="{StaticResource TextMuted}" BorderBrush="{StaticResource TextMuted}" 
                        BorderThickness="1" Cursor="Hand" Click="CancelBtn_Click"/>
                
                <Button x:Name="ConfirmBtn" Grid.Column="2" Content="确认执行" Width="100" Height="36"
                        Background="{StaticResource Warning}" Foreground="White" BorderThickness="0"
                        Cursor="Hand" Click="ConfirmBtn_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
