<Window x:Class="XIAOHAI.AI.UpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="检查更新"
        Height="500" Width="600"
        Background="#0a0b0f"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Icon="/ziyuan/bitbug_favicon.ico"
        ShowInTaskbar="False">
    
    <Window.Resources>
        <SolidColorBrush x:Key="BgDark" Color="#0a0b0f"/>
        <SolidColorBrush x:Key="BgCard" Color="#12141c"/>
        <SolidColorBrush x:Key="Border" Color="#6366f1"/>
        <SolidColorBrush x:Key="Text" Color="#e8eaf0"/>
        <SolidColorBrush x:Key="TextMuted" Color="#8b8fa8"/>
        <SolidColorBrush x:Key="Accent" Color="#6366f1"/>
        <SolidColorBrush x:Key="Success" Color="#10b981"/>
        <SolidColorBrush x:Key="Warning" Color="#f59e0b"/>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- 标题栏 -->
        <Border Grid.Row="0" Background="{StaticResource BgCard}" BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1" Padding="20,16">
            <StackPanel>
                <TextBlock Text="📦 发现新版本" x:Name="TitleText" 
                           Foreground="{StaticResource Accent}" FontWeight="SemiBold" FontSize="20"/>
                <TextBlock x:Name="SubtitleText" Text="检查更新中..." 
                           Foreground="{StaticResource TextMuted}" FontSize="13" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>
        
        <!-- 内容区 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20">
            <StackPanel>
                <!-- 版本信息 -->
                <Border x:Name="VersionInfoCard" Background="{StaticResource BgCard}" BorderBrush="{StaticResource Border}" 
                        BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="当前版本：" Foreground="{StaticResource TextMuted}" FontSize="13" Margin="0,0,0,4"/>
                        <TextBlock x:Name="CurrentVersionText" Grid.Row="1" Grid.Column="0" Text="-" Foreground="{StaticResource Text}" FontSize="14" FontWeight="SemiBold"/>
                        
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="最新版本：" Foreground="{StaticResource TextMuted}" FontSize="13" Margin="0,0,0,4"/>
                        <TextBlock x:Name="LatestVersionText" Grid.Row="1" Grid.Column="1" Text="-" Foreground="{StaticResource Success}" FontSize="14" FontWeight="SemiBold"/>
                        
                        <TextBlock x:Name="ReleaseDateText" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" 
                                   Text="" Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,8,0,0"/>
                    </Grid>
                </Border>
                
                <!-- 更新说明 -->
                <Border x:Name="ReleaseNotesCard" Background="{StaticResource BgCard}" BorderBrush="{StaticResource Border}" 
                        BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="📝 更新说明" Foreground="{StaticResource Text}" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8"/>
                        <Border Background="#1a1c25" CornerRadius="4" Padding="12">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="200">
                                <TextBlock x:Name="ReleaseNotesText" Text="加载中..." 
                                           Foreground="{StaticResource TextMuted}" FontSize="13" 
                                           TextWrapping="Wrap" LineHeight="20"/>
                            </ScrollViewer>
                        </Border>
                    </StackPanel>
                </Border>
                
                <!-- 下载进度 -->
                <Border x:Name="DownloadProgressCard" Background="{StaticResource BgCard}" BorderBrush="{StaticResource Border}" 
                        BorderThickness="1" CornerRadius="8" Padding="16" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="⬇️ 下载进度" Foreground="{StaticResource Text}" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ProgressBar x:Name="DownloadProgressBar" Grid.Column="0" Height="8" Minimum="0" Maximum="100" Value="0"
                                         Background="#1a1c25" Foreground="{StaticResource Accent}" BorderThickness="0"/>
                            <TextBlock x:Name="DownloadProgressText" Grid.Column="1" Text="0%" Foreground="{StaticResource TextMuted}" 
                                       FontSize="12" Margin="12,0,0,0" VerticalAlignment="Center"/>
                        </Grid>
                        <TextBlock x:Name="DownloadStatusText" Text="准备下载..." Foreground="{StaticResource TextMuted}" FontSize="12"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
        
        <!-- 按钮区 -->
        <Border Grid.Row="2" Background="{StaticResource BgCard}" BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0" Padding="20,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <Button x:Name="OpenUrlBtn" Grid.Column="0" Content="🌐 前往下载页" Width="100" Height="36" Margin="0,0,12,0"
                        Background="Transparent" Foreground="{StaticResource Accent}" BorderBrush="{StaticResource Accent}" 
                        BorderThickness="1" Cursor="Hand" Click="OpenUrlBtn_Click" Visibility="Collapsed"/>
                
                <Button x:Name="CancelBtn" Grid.Column="2" Content="取消" Width="80" Height="36" Margin="0,0,12,0"
                        Background="Transparent" Foreground="{StaticResource TextMuted}" BorderBrush="{StaticResource TextMuted}" 
                        BorderThickness="1" Cursor="Hand" Click="CancelBtn_Click"/>
                
                <Button x:Name="UpdateBtn" Grid.Column="3" Content="⬇️ 立即更新" Width="100" Height="36"
                        Background="{StaticResource Accent}" Foreground="White" BorderThickness="0"
                        Cursor="Hand" Click="UpdateBtn_Click" IsEnabled="False"/>
            </Grid>
        </Border>
    </Grid>
</Window>
