<Window x:Class="XIAOHAI.AI.PasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="管理密码" 
        Height="180" 
        Width="300"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#0a0b0f"
        Foreground="White"
        Icon="/ziyuan/bitbug_favicon.ico">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <TextBlock Grid.Row="0" 
                   Text="请输入管理密码:" 
                   Foreground="#e8eaf0" 
                   Margin="0,0,0,10"
                   HorizontalAlignment="Center"/>
        
        <PasswordBox x:Name="PasswordBox" 
                     Grid.Row="1" 
                     Margin="0,0,0,20"
                     Background="#12141c"
                     BorderBrush="#6366f1"
                     BorderThickness="1"
                     Foreground="#e8eaf0"
                     VerticalContentAlignment="Center"/>
        
        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Center">
            <Button Content="确定" 
                    Width="80" 
                    Height="30" 
                    Margin="0,0,10,0"
                    Click="OK_Click"
                    Background="#6366f1"
                    Foreground="White"
                    BorderThickness="0"/>
            <Button Content="取消" 
                    Width="80" 
                    Height="30" 
                    Click="Cancel_Click"
                    Background="#4b5563"
                    Foreground="White"
                    BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Window>