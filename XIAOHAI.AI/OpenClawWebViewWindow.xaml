<Window x:Class="XIAOHAI.AI.OpenClawWebViewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="龙虾小海 - OpenClaw WebUI"
        Height="800" Width="1200"
        MinHeight="500" MinWidth="700"
        Background="#0a0b0f"
        WindowStartupLocation="CenterScreen"
        Icon="/ziyuan/bitbug_favicon.ico"
        Closing="Window_Closing">
    <Window.Resources>
        <SolidColorBrush x:Key="BgDark" Color="#0a0b0f"/>
        <SolidColorBrush x:Key="BgCard" Color="#12141c"/>
        <SolidColorBrush x:Key="Border" Color="#6366f1"/>
        <SolidColorBrush x:Key="Text" Color="#e8eaf0"/>
        <SolidColorBrush x:Key="TextMuted" Color="#8b8fa8"/>
        <SolidColorBrush x:Key="Accent" Color="#6366f1"/>
        <SolidColorBrush x:Key="AccentPurple" Color="#8b5cf6"/>
        <LinearGradientBrush x:Key="AccentGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#6366f1" Offset="0"/>
            <GradientStop Color="#8b5cf6" Offset="1"/>
        </LinearGradientBrush>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource BgCard}" BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1" Padding="16,12">
            <StackPanel Orientation="Horizontal">
                <Image Source="./ziyuan/AIlogo.png" Width="24" Height="24" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <TextBlock Text="龙虾小海 - WebUI" 
                           Foreground="{StaticResource Text}" 
                           FontWeight="SemiBold" 
                           FontSize="16" 
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="StatusText" 
                           Text="正在加载..." 
                           Foreground="{StaticResource TextMuted}" 
                           FontSize="12" 
                           VerticalAlignment="Center" 
                           Margin="24,0,0,0"/>
                <Ellipse x:Name="StatusDot" 
                         Width="8" Height="8" 
                         Fill="{StaticResource TextMuted}" 
                         VerticalAlignment="Center" 
                         Margin="8,0,0,0"/>
            </StackPanel>
        </Border>

        <wv2:WebView2 x:Name="WebView" 
                      Grid.Row="1" 
                      DefaultBackgroundColor="#0a0b0f"
                      NavigationStarting="WebView_NavigationStarting"
                      NavigationCompleted="WebView_NavigationCompleted"
                      SourceChanged="WebView_SourceChanged"/>

        <Border Grid.Row="2" Background="{StaticResource BgCard}" BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0" Padding="16,12">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="BackBtn" 
                        Content="← 后退" 
                        Width="80" 
                        Height="36" 
                        Margin="0,0,8,0" 
                        Background="Transparent" 
                        Foreground="{StaticResource Text}" 
                        BorderThickness="1" 
                        BorderBrush="{StaticResource Border}"
                        Cursor="Hand" 
                        Click="BackBtn_Click"
                        FontSize="13"/>
                <Button x:Name="ForwardBtn" 
                        Content="前进 →" 
                        Width="80" 
                        Height="36" 
                        Margin="0,0,8,0" 
                        Background="Transparent" 
                        Foreground="{StaticResource Text}" 
                        BorderThickness="1" 
                        BorderBrush="{StaticResource Border}"
                        Cursor="Hand" 
                        Click="ForwardBtn_Click"
                        FontSize="13"/>
                <Button x:Name="RefreshBtn" 
                        Content="🔄 刷新" 
                        Width="80" 
                        Height="36" 
                        Margin="0,0,8,0" 
                        Background="Transparent" 
                        Foreground="{StaticResource Text}" 
                        BorderThickness="1" 
                        BorderBrush="{StaticResource Border}"
                        Cursor="Hand" 
                        Click="RefreshBtn_Click"
                        FontSize="13"/>
                <Button x:Name="HomeBtn" 
                        Content="🏠 首页" 
                        Width="80" 
                        Height="36" 
                        Margin="0,0,8,0" 
                        Background="Transparent" 
                        Foreground="{StaticResource Text}" 
                        BorderThickness="1" 
                        BorderBrush="{StaticResource Border}"
                        Cursor="Hand" 
                        Click="HomeBtn_Click"
                        FontSize="13"/>
                <Button x:Name="OpenInBrowserBtn" 
                        Content="🌐 在浏览器中打开" 
                        Width="120" 
                        Height="36" 
                        Margin="0,0,8,0" 
                        Background="{StaticResource AccentGradient}" 
                        Foreground="White" 
                        BorderThickness="0"
                        Cursor="Hand" 
                        Click="OpenInBrowserBtn_Click"
                        FontSize="13"/>
                <TextBlock x:Name="UrlText" 
                           Text="" 
                           Foreground="{StaticResource TextMuted}" 
                           FontSize="12" 
                           VerticalAlignment="Center" 
                           Margin="16,0,0,0"
                           Visibility="Hidden"
                           TextTrimming="CharacterEllipsis"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
