<Window x:Class="XIAOHAI.AI.KnowledgeBaseWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:XIAOHAI.AI"
        mc:Ignorable="d"
        Title="知识库管理"
        Height="650" Width="900"
        MinHeight="500" MinWidth="700"
        Background="#0a0b0f"
        WindowStartupLocation="CenterScreen"
        Icon="/ziyuan/bitbug_favicon.ico">
    <Window.Resources>
        <SolidColorBrush x:Key="BgDark" Color="#0a0b0f"/>
        <SolidColorBrush x:Key="BgCard" Color="#12141c"/>
        <SolidColorBrush x:Key="Border" Color="#6366f1"/>
        <SolidColorBrush x:Key="Text" Color="#e8eaf0"/>
        <SolidColorBrush x:Key="TextMuted" Color="#8b8fa8"/>
        <SolidColorBrush x:Key="Accent" Color="#6366f1"/>
        <SolidColorBrush x:Key="AccentPurple" Color="#8b5cf6"/>
        <SolidColorBrush x:Key="Success" Color="#22c55e"/>
        <SolidColorBrush x:Key="Warning" Color="#f59e0b"/>
        <SolidColorBrush x:Key="Danger" Color="#ef4444"/>
        <LinearGradientBrush x:Key="AccentGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#6366f1" Offset="0"/>
            <GradientStop Color="#8b5cf6" Offset="1"/>
        </LinearGradientBrush>
        
        <!-- 进度条样式 -->
        <Style x:Key="ModernProgressBar" TargetType="ProgressBar">
            <Setter Property="Background" Value="{StaticResource BgCard}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <Border x:Name="PART_Track" CornerRadius="4">
                                <Border x:Name="PART_Indicator" 
                                        Background="{StaticResource AccentGradient}" 
                                        CornerRadius="4"
                                        HorizontalAlignment="Left"/>
                            </Border>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- 顶部标题区 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <TextBlock Text="🧠" FontSize="24" Margin="0,0,12,0" VerticalAlignment="Center"/>
                <TextBlock Text="知识库管理" FontSize="24" FontWeight="Bold" Foreground="{StaticResource Text}" 
                           VerticalAlignment="Center"/>
            </StackPanel>
            <TextBlock Text="管理您的知识库，支持手动添加和文件导入，所有数据将自动存储到数据库并生成向量索引" 
                       FontSize="12" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap"/>
        </StackPanel>
        
        <!-- 操作按钮区 -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,20">
            <Button x:Name="AddManualBtn" Content="➕ 手动添加" Width="120" Height="36" Margin="0,0,10,0"
                    Background="{StaticResource AccentGradient}" Foreground="{StaticResource Text}"
                    BorderThickness="0" Cursor="Hand" Click="AddManualBtn_Click"/>
            <Button x:Name="ImportFileBtn" Content="📁 导入文件" Width="120" Height="36" Margin="0,0,10,0"
                    Background="{StaticResource AccentGradient}" Foreground="{StaticResource Text}"
                    BorderThickness="0" Cursor="Hand" Click="ImportFileBtn_Click"/>
            <Button x:Name="RefreshBtn" Content="🔄 刷新" Width="100" Height="36"
                    Background="Transparent" Foreground="{StaticResource Text}"
                    BorderBrush="{StaticResource Border}" BorderThickness="1" Cursor="Hand" Click="RefreshBtn_Click"/>
            <Button x:Name="BatchImportBtn" Content="📦 批量导入" Width="120" Height="36" Margin="0,0,10,0"
                    Background="{StaticResource AccentGradient}" Foreground="{StaticResource Text}"
                    BorderThickness="0" Cursor="Hand" Click="BatchImportBtn_Click"/>
        </StackPanel>
        
        <!-- 进度条区域 -->
        <Border Grid.Row="2" Background="{StaticResource BgCard}" 
                BorderBrush="{StaticResource Border}" BorderThickness="1" 
                CornerRadius="8" Padding="16" Margin="0,0,0,10"
                Visibility="{Binding ElementName=ProgressPanel, Path=Visibility}">
            <StackPanel x:Name="ProgressPanel" Visibility="Collapsed">
                <TextBlock x:Name="ProgressTitle" Text="正在处理..." FontSize="14" FontWeight="SemiBold" 
                           Foreground="{StaticResource Text}" Margin="0,0,0,8"/>
                <ProgressBar x:Name="SyncProgressBar" Style="{StaticResource ModernProgressBar}" 
                             Minimum="0" Maximum="100" Value="0" Margin="0,0,0,8"/>
                <TextBlock x:Name="ProgressText" Text="准备中..." FontSize="12" 
                           Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
        
        <!-- 知识库列表 -->
        <Border Grid.Row="2" Background="{StaticResource BgCard}" 
                BorderBrush="{StaticResource Border}" BorderThickness="1" 
                CornerRadius="8" Margin="0,0,0,10">
            <DataGrid x:Name="KnowledgeDataGrid"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      SelectionMode="Single"
                      IsSynchronizedWithCurrentItem="True"
                      Background="Transparent"
                      BorderThickness="0"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      RowHeaderWidth="0"
                      RowHeight="50">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#1e1f29"/>
                        <Setter Property="Foreground" Value="{StaticResource Text}"/>
                        <Setter Property="Padding" Value="12,8"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="{StaticResource Text}"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{StaticResource Border}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1e1f29"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="{StaticResource Text}"/>
                        <Setter Property="Padding" Value="12,8"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="Transparent"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.CellStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60" IsReadOnly="True"/>
                    <DataGridTextColumn Header="标题" Binding="{Binding Title}" Width="200" IsReadOnly="True"/>
                    <DataGridTextColumn Header="类型" Binding="{Binding Type}" Width="80" IsReadOnly="True"/>
                    <DataGridTextColumn Header="压缩状态" Binding="{Binding CompressionStatusDisplay}" Width="90" IsReadOnly="True"/>
                    <DataGridTextColumn Header="锁定状态" Binding="{Binding LockStatusDisplay}" Width="90" IsReadOnly="True"/>
                    <DataGridTemplateColumn Header="操作" Width="280">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button x:Name="CompressButton" Content="🗜️ 压缩" Width="65" Height="26" Margin="0,0,5,0"
                                            Background="{StaticResource Warning}" Foreground="{StaticResource Text}"
                                            BorderThickness="0" Cursor="Hand" Tag="{Binding}" Click="CompressBtn_Click"/>
                                    <Button x:Name="LockUnlockButton" Content="{Binding LockButtonText}" Width="50" Height="26" Margin="0,0,5,0"
                                            Background="{StaticResource AccentPurple}" Foreground="{StaticResource Text}"
                                            BorderThickness="0" Cursor="Hand" Tag="{Binding}" Click="LockUnlockBtn_Click"/>
                                    <Button x:Name="EditButton" Content="✏️ 编辑" Width="50" Height="26" Margin="0,0,5,0"
                                            Background="{StaticResource AccentGradient}" Foreground="{StaticResource Text}"
                                            BorderThickness="0" Cursor="Hand" Tag="{Binding}" Click="EditBtn_Click"/>
                                    <Button x:Name="DeleteButton" Content="🗑️ 删除" Width="50" Height="26"
                                            Background="{StaticResource Danger}" Foreground="{StaticResource Text}"
                                            BorderThickness="0" Cursor="Hand" Tag="{Binding}" Click="DeleteBtn_Click"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
        
        <!-- 状态栏 -->
        <Border Grid.Row="3" Background="{StaticResource BgCard}" 
                BorderBrush="{StaticResource Border}" BorderThickness="1" 
                CornerRadius="8" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock x:Name="StatusText" Grid.Column="0" 
                           Text="✓ 就绪" Foreground="{StaticResource Success}" 
                           FontSize="13" VerticalAlignment="Center"/>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Border Background="#1e1f29" BorderBrush="{StaticResource Border}" 
                            BorderThickness="1" CornerRadius="6" Padding="12,6" Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📊" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <StackPanel>
                                <TextBlock Text="知识库条目" FontSize="10" Foreground="{StaticResource TextMuted}"/>
                                <TextBlock x:Name="ItemCountText" Text="0 条" FontSize="14" FontWeight="SemiBold" 
                                           Foreground="{StaticResource Text}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    
                    <Border Background="#1e1f29" BorderBrush="{StaticResource Border}" 
                            BorderThickness="1" CornerRadius="6" Padding="12,6">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🧮" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <StackPanel>
                                <TextBlock Text="向量索引" FontSize="10" Foreground="{StaticResource TextMuted}"/>
                                <TextBlock x:Name="VectorCountText" Text="0 个" FontSize="14" FontWeight="SemiBold" 
                                           Foreground="{StaticResource Success}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
