<Window x:Class="XIAOHAI.AI.TutorialWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="小海 · 使用教程"
        Height="700" Width="900"
        WindowStartupLocation="CenterOwner"
        Background="#0a0b0f"
        Icon="/ziyuan/bitbug_favicon.ico">
    
    <Window.Resources>
        <SolidColorBrush x:Key="BgDark" Color="#0a0b0f"/>
        <SolidColorBrush x:Key="BgCard" Color="#12141c"/>
        <SolidColorBrush x:Key="Border" Color="#6366f1"/>
        <SolidColorBrush x:Key="Text" Color="#e8eaf0"/>
        <SolidColorBrush x:Key="TextMuted" Color="#8b8fa8"/>
        <SolidColorBrush x:Key="Accent" Color="#6366f1"/>
        <SolidColorBrush x:Key="AccentPurple" Color="#8b5cf6"/>
        <SolidColorBrush x:Key="Success" Color="#22c55e"/>
        <SolidColorBrush x:Key="Warning" Color="#f59e0b"/>
        <SolidColorBrush x:Key="Info" Color="#3b82f6"/>
        <LinearGradientBrush x:Key="AccentGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#6366f1" Offset="0"/>
            <GradientStop Color="#8b5cf6" Offset="1"/>
        </LinearGradientBrush>
    </Window.Resources>
    
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- 标题栏 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <TextBlock Text="📖" FontSize="28" Margin="0,0,12,0" VerticalAlignment="Center"/>
                <TextBlock Text="小海 · 使用教程" FontSize="28" FontWeight="Bold" Foreground="{StaticResource Text}" 
                           VerticalAlignment="Center"/>
            </StackPanel>
            <TextBlock Text="快速了解小海 AI 助手的各项功能和使用方法" 
                       FontSize="14" Foreground="{StaticResource TextMuted}"/>
        </StackPanel>
        
        <!-- 内容区域 - TabControl -->
        <TabControl Grid.Row="1" Margin="0,0,0,20">
            <TabItem Header="🏠 软件介绍">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                    <StackPanel>
                        <!-- 简介卡片 -->
                        <Border Background="{StaticResource BgCard}" BorderBrush="{StaticResource Border}" 
                                BorderThickness="1" CornerRadius="12" Padding="20" Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock Text="🤖 关于小海 AI" FontSize="20" FontWeight="Bold" 
                                           Foreground="{StaticResource Text}" Margin="0,0,0,12"/>
                                <TextBlock Text="小海 AI 是一款功能强大的本地智能对话助手，基于 Ollama 大模型技术，为您提供智能对话、知识库管理、联网搜索、系统控制等多种功能。" 
                                           FontSize="14" Foreground="{StaticResource Text}" TextWrapping="Wrap" LineHeight="22"/>
                            </StackPanel>
                        </Border>
                        
                        <!-- 核心功能 -->
                        <Border Background="{StaticResource BgCard}" BorderBrush="{StaticResource Border}" 
                                BorderThickness="1" CornerRadius="12" Padding="20" Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock Text="✨ 核心功能" FontSize="20" FontWeight="Bold" 
                                           Foreground="{StaticResource Text}" Margin="0,0,0,16"/>
                                
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    
                                    <!-- 功能 1 -->
                                    <Border Grid.Row="0" Grid.Column="0" Background="#1a1c26" CornerRadius="8" Padding="16" Margin="0,0,10,10">
                                        <StackPanel>
                                            <TextBlock Text="💬 智能对话" FontSize="16" FontWeight="SemiBold" 
                                                       Foreground="{StaticResource Accent}" Margin="0,0,0,8"/>
                                            <TextBlock Text="支持多轮对话、上下文理解、打字机效果显示" 
                                                       FontSize="13" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                    
                                    <!-- 功能 2 -->
                                    <Border Grid.Row="0" Grid.Column="1" Background="#1a1c26" CornerRadius="8" Padding="16" Margin="10,0,0,10">
                                        <StackPanel>
                                            <TextBlock Text="🧠 知识库" FontSize="16" FontWeight="SemiBold" 
                                                       Foreground="{StaticResource AccentPurple}" Margin="0,0,0,8"/>
                                            <TextBlock Text="支持导入文档、语义检索、AI 智能压缩" 
                                                       FontSize="13" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                    
                                    <!-- 功能 3 -->
                                    <Border Grid.Row="1" Grid.Column="0" Background="#1a1c26" CornerRadius="8" Padding="16" Margin="0,0,10,0">
                                        <StackPanel>
                                            <TextBlock Text="🌐 联网搜索" FontSize="16" FontWeight="SemiBold" 
                                                       Foreground="{StaticResource Info}" Margin="0,0,0,8"/>
                                            <TextBlock Text="集成百度千帆搜索、实时网络信息检索" 
                                                       FontSize="13" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                    
                                    <!-- 功能 4 -->
                                    <Border Grid.Row="1" Grid.Column="0" Background="#1a1c26" CornerRadius="8" Padding="16" Margin="0,0,10,0">
                                        <StackPanel>
                                            <TextBlock Text="🤖 桌面自动化" FontSize="16" FontWeight="SemiBold" 
                                                       Foreground="{StaticResource Success}" Margin="0,0,0,8"/>
                                            <TextBlock Text="Python 脚本生成、技能库管理、自动执行任务" 
                                                       FontSize="13" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                    
                                    <!-- 功能 5 -->
                                    <Border Grid.Row="1" Grid.Column="1" Background="#1a1c26" CornerRadius="8" Padding="16" Margin="10,0,0,0">
                                        <StackPanel>
                                            <TextBlock Text="🖥️ 系统控制" FontSize="16" FontWeight="SemiBold" 
                                                       Foreground="{StaticResource Warning}" Margin="0,0,0,8"/>
                                            <TextBlock Text="智能识别意图、执行系统操作、安全确认机制" 
                                                       FontSize="13" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>
                        
                        <!-- 技术特点 -->
                        <Border Background="{StaticResource BgCard}" BorderBrush="{StaticResource Border}" 
                                BorderThickness="1" CornerRadius="12" Padding="20">
                            <StackPanel>
                                <TextBlock Text="🚀 技术特点" FontSize="20" FontWeight="Bold" 
                                           Foreground="{StaticResource Text}" Margin="0,0,0,16"/>
                                <StackPanel>
                                    <TextBlock Text="✓ 本地部署 · 隐私安全" FontSize="14" Foreground="{StaticResource Text}" Margin="0,0,0,8"/>
                                    <TextBlock Text="✓ 支持多种大语言模型" FontSize="14" Foreground="{StaticResource Text}" Margin="0,0,0,8"/>
                                    <TextBlock Text="✓ 向量数据库 · 语义检索" FontSize="14" Foreground="{StaticResource Text}" Margin="0,0,0,8"/>
                                    <TextBlock Text="✓ 视觉识别 · 图片理解" FontSize="14" Foreground="{StaticResource Text}" Margin="0,0,0,8"/>
                                    <TextBlock Text="✓ 悬浮球 · 随时待命" FontSize="14" Foreground="{StaticResource Text}" Margin="0,0,0,8"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            
            <TabItem Header="💬 基础使用">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                    <StackPanel>
                        <!-- 快速开始 -->
                        <Border Background="{StaticResource BgCard}" BorderBrush="{StaticResource Border}" 
                                BorderThickness="1" CornerRadius="12" Padding="20" Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock Text="🚀 快速开始" FontSize="20" FontWeight="Bold" 
                                           Foreground="{StaticResource Text}" Margin="0,0,0,16"/>
                                
                                <Border Background="#1a1c26" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="步骤 1: 确保 Ollama 已安装并运行" FontSize="14" FontWeight="SemiBold" 
                                                   Foreground="{StaticResource Accent}" Margin="0,0,0,4"/>
                                        <TextBlock Text="下载安装 Ollama：https://ollama.com" FontSize="13" Foreground="{StaticResource TextMuted}"/>
                                    </StackPanel>
                                </Border>
                                
                                <Border Background="#1a1c26" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="步骤 2: 拉取所需模型" FontSize="14" FontWeight="SemiBold" 
                                                   Foreground="{StaticResource Accent}" Margin="0,0,0,4"/>
                                        <TextBlock Text="命令行执行：ollama pull glm-4.7-flash（对话模型）" FontSize="13" Foreground="{StaticResource TextMuted}"/>
                                        <TextBlock Text="命令行执行：ollama pull llava（视觉模型）" FontSize="13" Foreground="{StaticResource TextMuted}"/>
                                    </StackPanel>
                                </Border>
                                
                                <Border Background="#1a1c26" CornerRadius="8" Padding="16">
                                    <StackPanel>
                                        <TextBlock Text="步骤 3: 配置并开始使用" FontSize="14" FontWeight="SemiBold" 
                                                   Foreground="{StaticResource Accent}" Margin="0,0,0,4"/>
                                        <TextBlock Text="点击设置按钮 → 输入密码 admin888 → 确认模型配置 → 开始对话" FontSize="13" Foreground="{StaticResource TextMuted}"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                        
                        <!-- 对话技巧 -->
                        <Border Background="{StaticResource BgCard}" BorderBrush="{StaticResource Border}" 
                                BorderThickness="1" CornerRadius="12" Padding="20">
                            <StackPanel>
                                <TextBlock Text="💡 对话技巧" FontSize="20" FontWeight="Bold" 
                                           Foreground="{StaticResource Text}" Margin="0,0,0,16"/>
                                
                                <StackPanel Margin="0,0,0,12">
                                    <TextBlock Text="• 清晰描述问题" FontSize="14" Foreground="{StaticResource Text}" Margin="0,0,0,6"/>
                                    <TextBlock Text="  示例：&quot;如何用 Python 读取 Excel 文件？&quot;" FontSize="13" Foreground="{StaticResource TextMuted}" Margin="20,0,0,0"/>
                                </StackPanel>
                                
                                <StackPanel Margin="0,0,0,12">
                                    <TextBlock Text="• 提供上下文信息" FontSize="14" Foreground="{StaticResource Text}" Margin="0,0,0,6"/>
                                    <TextBlock Text="  示例：&quot;我想做一个数据分析项目，需要处理 10 万行数据，用什么库比较好？&quot;" FontSize="13" Foreground="{StaticResource TextMuted}" Margin="20,0,0,0"/>
                                </StackPanel>
                                
                                <StackPanel Margin="0,0,0,12">
                                    <TextBlock Text="• 使用 Shift+Enter 换行" FontSize="14" Foreground="{StaticResource Text}" Margin="0,0,0,6"/>
                                    <TextBlock Text="  Enter 发送消息，Shift+Enter 换行输入多行内容" FontSize="13" Foreground="{StaticResource TextMuted}" Margin="20,0,0,0"/>
                                </StackPanel>
                                
                                <StackPanel>
                                    <TextBlock Text="• 支持图片识别" FontSize="14" Foreground="{StaticResource Text}" Margin="0,0,0,6"/>
                                    <TextBlock Text="  直接粘贴截图到输入框，AI 会自动识别图片内容" FontSize="13" Foreground="{StaticResource TextMuted}" Margin="20,0,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            
            <TabItem Header="🧠 知识库">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                    <StackPanel>
                        <Border Background="{StaticResource BgCard}" BorderBrush="{StaticResource Border}" 
                                BorderThickness="1" CornerRadius="12" Padding="20" Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock Text="📚 知识库功能" FontSize="20" FontWeight="Bold" 
                                           Foreground="{StaticResource Text}" Margin="0,0,0,12"/>
                                <TextBlock Text="知识库可以让 AI 在回答问题时参考您提供的专业资料，提高回答的准确性和专业性。" 
                                           FontSize="14" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap" Margin="0,0,0,20"/>
                                
                                <TextBlock Text="使用方法：" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource Accent}" Margin="0,0,0,12"/>
                                
                                <StackPanel Margin="0,0,0,12">
                                    <TextBlock Text="1. 点击侧边栏的&quot;🧠 知识库&quot;按钮" FontSize="14" Foreground="{StaticResource Text}" Margin="0,0,0,6"/>
                                </StackPanel>
                                
                                <StackPanel Margin="0,0,0,12">
                                    <TextBlock Text="2. 添加知识：" FontSize="14" Foreground="{StaticResource Text}" Margin="0,0,0,6"/>
                                    <TextBlock Text="   • 手动添加：点击&quot;➕ 手动添加&quot;按钮，输入标题和内容" FontSize="13" Foreground="{StaticResource TextMuted}" Margin="0,0,0,4"/>
                                    <TextBlock Text="   • 导入文件：点击&quot;📁 导入文件&quot;，支持 TXT、DOCX、PDF、Excel 等格式" FontSize="13" Foreground="{StaticResource TextMuted}" Margin="0,0,0,4"/>
                                </StackPanel>
                                
                                <StackPanel Margin="0,0,0,12">
                                    <TextBlock Text="3. 同步向量：点击&quot;💾 保存并同步&quot;，为知识条目生成向量索引" FontSize="14" Foreground="{StaticResource Text}" Margin="0,0,0,6"/>
                                </StackPanel>
                                
                                <StackPanel Margin="0,0,0,12">
                                    <TextBlock Text="4. 知识管理：" FontSize="14" Foreground="{StaticResource Text}" Margin="0,0,0,6"/>
                                    <TextBlock Text="   • 🗜️ 压缩：使用 AI 压缩知识内容，节省空间" FontSize="13" Foreground="{StaticResource TextMuted}" Margin="0,0,0,4"/>
                                    <TextBlock Text="   • 🔒 锁定：保护重要知识不被误删" FontSize="13" Foreground="{StaticResource TextMuted}" Margin="0,0,0,4"/>
                                    <TextBlock Text="   • ✏️ 编辑：修改知识内容" FontSize="13" Foreground="{StaticResource TextMuted}" Margin="0,0,0,4"/>
                                    <TextBlock Text="   • 🗑️ 删除：移除不需要的知识" FontSize="13" Foreground="{StaticResource TextMuted}" Margin="0,0,0,4"/>
                                </StackPanel>
                                
                                <Border Background="#1a1c26" CornerRadius="8" Padding="16" Margin="0,12,0,0">
                                    <StackPanel>
                                        <TextBlock Text="💡 提示" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource Info}" Margin="0,0,0,8"/>
                                        <TextBlock Text="• AI 回答问题时会自动检索相关知识库内容" FontSize="13" Foreground="{StaticResource TextMuted}" Margin="0,0,0,4"/>
                                        <TextBlock Text="• 知识库内容全部存储在本地 SQLite 数据库" FontSize="13" Foreground="{StaticResource TextMuted}" Margin="0,0,0,4"/>
                                        <TextBlock Text="• 定期维护知识库可以获得更好的 AI 回答质量" FontSize="13" Foreground="{StaticResource TextMuted}"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            
            <TabItem Header="🔍 高级功能">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                    <StackPanel>
                        <!-- 桌面自动化 -->
                        <Border Background="{StaticResource BgCard}" BorderBrush="{StaticResource Border}" 
                                BorderThickness="1" CornerRadius="12" Padding="20" Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock Text="🤖 桌面自动化" FontSize="20" FontWeight="Bold" 
                                           Foreground="{StaticResource Success}" Margin="0,0,0,12"/>
                                <TextBlock Text="AI 智能生成 Python 脚本，自动执行桌面任务" FontSize="14" Foreground="{StaticResource TextMuted}" Margin="0,0,0,16"/>
                                
                                <TextBlock Text="使用步骤：" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource Text}" Margin="0,0,0,12"/>
                                <TextBlock Text="1. 点击侧边栏的&quot;🤖 自动化&quot;按钮" FontSize="14" Foreground="{StaticResource Text}" Margin="0,0,0,6"/>
                                <TextBlock Text="2. 在聊天窗口输入任务描述（如&quot;帮我打开记事本&quot;）" FontSize="14" Foreground="{StaticResource Text}" Margin="0,0,0,6"/>
                                <TextBlock Text="3. AI 分析任务并生成 Python 脚本" FontSize="14" Foreground="{StaticResource Text}" Margin="0,0,0,6"/>
                                <TextBlock Text="4. 安全检查（有风险操作会提示确认）" FontSize="14" Foreground="{StaticResource Text}" Margin="0,0,0,6"/>
                                <TextBlock Text="5. 执行脚本并自动保存到技能库" FontSize="14" Foreground="{StaticResource Text}" Margin="0,0,0,6"/>
                                
                                <TextBlock Text="技能管理：" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource Text}" Margin="0,16,0,12"/>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    
                                    <Border Grid.Row="0" Grid.Column="0" Background="#1a1c26" CornerRadius="6" Padding="12" Margin="0,0,8,8">
                                        <StackPanel>
                                            <TextBlock Text="▶ 执行" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource Success}" Margin="0,0,0,4"/>
                                            <TextBlock Text="直接运行技能脚本" FontSize="12" Foreground="{StaticResource TextMuted}"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Row="0" Grid.Column="1" Background="#1a1c26" CornerRadius="6" Padding="12" Margin="8,0,0,8">
                                        <StackPanel>
                                            <TextBlock Text="✏ 编辑" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource Warning}" Margin="0,0,0,4"/>
                                            <TextBlock Text="查看和修改代码" FontSize="12" Foreground="{StaticResource TextMuted}"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Row="1" Grid.Column="0" Background="#1a1c26" CornerRadius="6" Padding="12" Margin="0,0,8,0">
                                        <StackPanel>
                                            <TextBlock Text="📝 重命名" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource Accent}" Margin="0,0,0,4"/>
                                            <TextBlock Text="修改技能名称" FontSize="12" Foreground="{StaticResource TextMuted}"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Row="1" Grid.Column="1" Background="#1a1c26" CornerRadius="6" Padding="12" Margin="8,0,0,0">
                                        <StackPanel>
                                            <TextBlock Text="🗑 删除" FontSize="14" FontWeight="SemiBold" Foreground="#ef4444" Margin="0,0,0,4"/>
                                            <TextBlock Text="移除技能" FontSize="12" Foreground="{StaticResource TextMuted}"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                                
                                <Border Background="#1a1c26" CornerRadius="8" Padding="16">
                                    <StackPanel>
                                        <TextBlock Text="💡 技术说明" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource Info}" Margin="0,0,0,8"/>
                                        <TextBlock Text="• 使用 IronPython 执行脚本（基于.NET 的 Python）" FontSize="13" Foreground="{StaticResource TextMuted}" Margin="0,0,0,4"/>
                                        <TextBlock Text="• 脚本使用 .NET 类库而非 Python 标准库" FontSize="13" Foreground="{StaticResource TextMuted}" Margin="0,0,0,4"/>
                                        <TextBlock Text="• 常用库：System.Diagnostics, System.IO, System.Windows.Forms" FontSize="13" Foreground="{StaticResource TextMuted}" Margin="0,0,0,4"/>
                                        <TextBlock Text="• 示例代码：Process.Start(&quot;notepad.exe&quot;)" FontSize="13" Foreground="{StaticResource TextMuted}"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                        
                        <!-- 联网搜索 -->
                        <Border Background="{StaticResource BgCard}" BorderBrush="{StaticResource Border}" 
                                BorderThickness="1" CornerRadius="12" Padding="20" Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock Text="🌐 联网搜索" FontSize="20" FontWeight="Bold" 
                                           Foreground="{StaticResource Info}" Margin="0,0,0,12"/>
                                <TextBlock Text="让 AI 获取实时网络信息" FontSize="14" Foreground="{StaticResource TextMuted}" Margin="0,0,0,16"/>
                                
                                <TextBlock Text="配置步骤：" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource Text}" Margin="0,0,0,12"/>
                                <TextBlock Text="1. 点击&quot;⚙ 设置&quot;按钮（需密码 联系管理员）" FontSize="14" Foreground="{StaticResource Text}" Margin="0,0,0,6"/>
                                <TextBlock Text="2. 切换到&quot;搜索引擎&quot;标签页" FontSize="14" Foreground="{StaticResource Text}" Margin="0,0,0,6"/>
                                <TextBlock Text="3. 填写百度千帆 API 密钥和用户 ID" FontSize="14" Foreground="{StaticResource Text}" Margin="0,0,0,6"/>
                                <TextBlock Text="4. 获取 API 密钥：https://console.bce.baidu.com/" FontSize="13" Foreground="{StaticResource TextMuted}" Margin="0,0,0,12"/>
                                
                                <Border Background="#1a1c26" CornerRadius="8" Padding="16">
                                    <StackPanel>
                                        <TextBlock Text="💡 使用技巧" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource Info}" Margin="0,0,0,8"/>
                                        <TextBlock Text="• 询问时事新闻、天气、股票等实时信息时启用" FontSize="13" Foreground="{StaticResource TextMuted}" Margin="0,0,0,4"/>
                                        <TextBlock Text="• AI 会自动判断是否需要搜索" FontSize="13" Foreground="{StaticResource TextMuted}" Margin="0,0,0,4"/>
                                        <TextBlock Text="• 搜索结果会显示在对话气泡中" FontSize="13" Foreground="{StaticResource TextMuted}"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                        
                        <!-- 系统控制 -->
                        <Border Background="{StaticResource BgCard}" BorderBrush="{StaticResource Border}" 
                                BorderThickness="1" CornerRadius="12" Padding="20" Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock Text="🖥️ 系统控制" FontSize="20" FontWeight="Bold" 
                                           Foreground="{StaticResource Warning}" Margin="0,0,0,12"/>
                                <TextBlock Text="让 AI 智能执行系统操作" FontSize="14" Foreground="{StaticResource TextMuted}" Margin="0,0,0,16"/>
                                
                                <TextBlock Text="启用方法：" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource Text}" Margin="0,0,0,12"/>
                                <TextBlock Text="点击主界面右上角的&quot;⚡ 系统控制&quot;开关" FontSize="14" Foreground="{StaticResource Text}" Margin="0,0,0,12"/>
                                
                                <TextBlock Text="支持的命令：" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource Text}" Margin="0,0,0,12"/>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    
                                    <Border Grid.Row="0" Grid.Column="0" Background="#1a1c26" CornerRadius="6" Padding="12" Margin="0,0,8,8">
                                        <TextBlock Text="📊 系统信息查询" FontSize="13" Foreground="{StaticResource Text}"/>
                                    </Border>
                                    <Border Grid.Row="0" Grid.Column="1" Background="#1a1c26" CornerRadius="6" Padding="12" Margin="8,0,0,8">
                                        <TextBlock Text="🗑️ 清理系统垃圾" FontSize="13" Foreground="{StaticResource Text}"/>
                                    </Border>
                                    <Border Grid.Row="1" Grid.Column="0" Background="#1a1c26" CornerRadius="6" Padding="12" Margin="0,0,8,8">
                                        <TextBlock Text="📁 整理桌面文件" FontSize="13" Foreground="{StaticResource Text}"/>
                                    </Border>
                                    <Border Grid.Row="1" Grid.Column="1" Background="#1a1c26" CornerRadius="6" Padding="12" Margin="8,0,0,8">
                                        <TextBlock Text="⚙️ 进程管理" FontSize="13" Foreground="{StaticResource Text}"/>
                                    </Border>
                                    <Border Grid.Row="2" Grid.Column="0" Background="#1a1c26" CornerRadius="6" Padding="12" Margin="0,0,8,0">
                                        <TextBlock Text="🌐 网络诊断" FontSize="13" Foreground="{StaticResource Text}"/>
                                    </Border>
                                    <Border Grid.Row="2" Grid.Column="1" Background="#1a1c26" CornerRadius="6" Padding="12" Margin="8,0,0,0">
                                        <TextBlock Text="🔌 系统控制（重启/关机）" FontSize="13" Foreground="{StaticResource Text}"/>
                                    </Border>
                                </Grid>
                                
                                <Border Background="#2a2c36" CornerRadius="8" Padding="16">
                                    <StackPanel>
                                        <TextBlock Text="⚠️ 安全提示" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource Warning}" Margin="0,0,0,8"/>
                                        <TextBlock Text="• 危险操作会弹出确认对话框" FontSize="13" Foreground="{StaticResource TextMuted}" Margin="0,0,0,4"/>
                                        <TextBlock Text="• 建议仅在受信任的环境中使用" FontSize="13" Foreground="{StaticResource TextMuted}" Margin="0,0,0,4"/>
                                        <TextBlock Text="• AI 会智能识别意图，避免误操作" FontSize="13" Foreground="{StaticResource TextMuted}"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                        
                        <!-- 视觉识别 -->
                        <Border Background="{StaticResource BgCard}" BorderBrush="{StaticResource Border}" 
                                BorderThickness="1" CornerRadius="12" Padding="20">
                            <StackPanel>
                                <TextBlock Text="🔍 视觉识别" FontSize="20" FontWeight="Bold" 
                                           Foreground="{StaticResource AccentPurple}" Margin="0,0,0,12"/>
                                <TextBlock Text="图片识别与智能填表" FontSize="14" Foreground="{StaticResource TextMuted}" Margin="0,0,0,16"/>
                                
                                <TextBlock Text="使用步骤：" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource Text}" Margin="0,0,0,12"/>
                                <TextBlock Text="1. 点击&quot;🔍 视觉识别&quot;按钮" FontSize="14" Foreground="{StaticResource Text}" Margin="0,0,0,6"/>
                                <TextBlock Text="2. 选择图片文件（身份证、表单、文档等）" FontSize="14" Foreground="{StaticResource Text}" Margin="0,0,0,6"/>
                                <TextBlock Text="3. 点击&quot;🔍 识别图片&quot;，AI 提取内容" FontSize="14" Foreground="{StaticResource Text}" Margin="0,0,0,6"/>
                                <TextBlock Text="4. 输入目标网页 URL" FontSize="14" Foreground="{StaticResource Text}" Margin="0,0,0,6"/>
                                <TextBlock Text="5. 点击&quot;✏️ 自动填表&quot;，AI 智能填充表单" FontSize="14" Foreground="{StaticResource Text}" Margin="0,0,0,6"/>
                                
                                <Border Background="#1a1c26" CornerRadius="8" Padding="16" Margin="0,12,0,0">
                                    <StackPanel>
                                        <TextBlock Text="💡 提示" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource Info}" Margin="0,0,0,8"/>
                                        <TextBlock Text="• 首次使用前请安装视觉模型：ollama pull llava" FontSize="13" Foreground="{StaticResource TextMuted}" Margin="0,0,0,4"/>
                                        <TextBlock Text="• 支持识别身份证、银行卡、发票等证件" FontSize="13" Foreground="{StaticResource TextMuted}" Margin="0,0,0,4"/>
                                        <TextBlock Text="• 支持识别并填充网页表单" FontSize="13" Foreground="{StaticResource TextMuted}"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            
            <TabItem Header="❓ 常见问题">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                    <StackPanel>
                        <!-- 问题 1 -->
                        <Border Background="{StaticResource BgCard}" BorderBrush="{StaticResource Border}" 
                                BorderThickness="1" CornerRadius="12" Padding="20" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Q: 为什么 AI 回答很慢？" FontSize="16" FontWeight="SemiBold" 
                                           Foreground="{StaticResource Accent}" Margin="0,0,0,8"/>
                                <TextBlock Text="A: 回答速度取决于您的硬件配置和模型大小。建议使用 4bit 量化模型（如 glm-4.7-flash），并确保有足够的 RAM（至少 8GB）。使用 SSD 硬盘也能提升加载速度。" 
                                           FontSize="14" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                        
                        <!-- 问题 2 -->
                        <Border Background="{StaticResource BgCard}" BorderBrush="{StaticResource Border}" 
                                BorderThickness="1" CornerRadius="12" Padding="20" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Q: 如何更换 AI 模型？" FontSize="16" FontWeight="SemiBold" 
                                           Foreground="{StaticResource Accent}" Margin="0,0,0,8"/>
                                <TextBlock Text="A: 点击&quot;⚙ 设置&quot;（密码：admin888）→ 在&quot;本地模型&quot;标签页点击&quot;🔄 刷新可用模型&quot; → 从下拉列表选择所需模型 → 保存设置。确保已使用 ollama pull 拉取该模型。" 
                                           FontSize="14" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                        
                        <!-- 问题 3 -->
                        <Border Background="{StaticResource BgCard}" BorderBrush="{StaticResource Border}" 
                                BorderThickness="1" CornerRadius="12" Padding="20" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Q: 知识库有什么作用？" FontSize="16" FontWeight="SemiBold" 
                                           Foreground="{StaticResource Accent}" Margin="0,0,0,8"/>
                                <TextBlock Text="A: 知识库可以让 AI 记住您的专业资料、公司文档、个人笔记等内容。当 AI 回答问题时，会自动检索相关知识，提供更准确、更专业的答案。适合构建个人知识库、企业知识库等场景。" 
                                           FontSize="14" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                        
                        <!-- 问题 4 -->
                        <Border Background="{StaticResource BgCard}" BorderBrush="{StaticResource Border}" 
                                BorderThickness="1" CornerRadius="12" Padding="20" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Q: 悬浮球如何使用？" FontSize="16" FontWeight="SemiBold" 
                                           Foreground="{StaticResource Accent}" Margin="0,0,0,8"/>
                                <TextBlock Text="A: 悬浮球默认显示在屏幕右下角。双击悬浮球可打开主窗口，右击悬浮球可打开菜单（查看当前问题、打开主窗口、隐藏悬浮球）。" 
                                           FontSize="14" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                        
                        <!-- 问题 5 -->
                        <Border Background="{StaticResource BgCard}" BorderBrush="{StaticResource Border}" 
                                BorderThickness="1" CornerRadius="12" Padding="20" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Q: 如何备份数据？" FontSize="16" FontWeight="SemiBold" 
                                           Foreground="{StaticResource Accent}" Margin="0,0,0,8"/>
                                <TextBlock Text="A: 所有数据都存储在程序目录下的文件中：knowledge_vectors.db（知识库数据库）、settings.json（设置）、chat_history_main.json（聊天记录）。备份这些文件即可，恢复时直接覆盖。" 
                                           FontSize="14" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                        
                        <!-- 问题 6 -->
                        <Border Background="{StaticResource BgCard}" BorderBrush="{StaticResource Border}" 
                                BorderThickness="1" CornerRadius="12" Padding="20">
                            <StackPanel>
                                <TextBlock Text="Q: 联网搜索失败怎么办？" FontSize="16" FontWeight="SemiBold" 
                                           Foreground="{StaticResource Accent}" Margin="0,0,0,8"/>
                                <TextBlock Text="A: 首先检查是否已配置百度千帆 API 密钥（设置 → 搜索引擎）。如果已配置但仍失败，可能是 API 额度用尽或网络问题。也可以关闭联网搜索功能，AI 会使用已有知识回答。" 
                                           FontSize="14" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
        
        <!-- 底部按钮 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="CloseBtn" Content="关闭教程" Width="120" Height="40" 
                    Background="{StaticResource AccentGradient}" Foreground="White" 
                    BorderThickness="0" Cursor="Hand" Click="CloseBtn_Click" FontSize="14"/>
        </StackPanel>
    </Grid>
</Window>
