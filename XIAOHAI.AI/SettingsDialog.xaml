<Window x:Class="XIAOHAI.AI.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="设置" 
        Height="600" Width="550"
        WindowStartupLocation="CenterOwner"
        Background="#0a0b0f"
        ResizeMode="NoResize"
        Icon="/ziyuan/bitbug_favicon.ico">
    <Window.Resources>
        <SolidColorBrush x:Key="BgDark" Color="#0a0b0f"/>
        <SolidColorBrush x:Key="BgCard" Color="#12141c"/>
        <SolidColorBrush x:Key="Border" Color="#6366f1"/>
        <SolidColorBrush x:Key="Text" Color="White"/>
        <SolidColorBrush x:Key="TextMuted" Color="#8b8fa8"/>
        <SolidColorBrush x:Key="Accent" Color="#6366f1"/>
        <SolidColorBrush x:Key="AccentPurple" Color="#8b5cf6"/>
        <LinearGradientBrush x:Key="AccentGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#6366f1" Offset="0"/>
            <GradientStop Color="#8b5cf6" Offset="1"/>
        </LinearGradientBrush>
    </Window.Resources>
    
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- 标题栏 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,24">
            <Image Source="./ziyuan/AIlogo.png" Width="28" Height="28" VerticalAlignment="Center" Margin="0,0,12,0"/>
            <TextBlock Text="设置" 
                       Foreground="{StaticResource Text}" 
                       FontSize="24" 
                       FontWeight="SemiBold" 
                       VerticalAlignment="Center"/>
        </StackPanel>
        
        <!-- TabControl -->
        <TabControl Grid.Row="1" 
                    Margin="0,0,0,20">
            
            <!-- Ollama 设置标签页 -->
            <TabItem Header="本地模型">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Background="{StaticResource BgCard}">
                        <TextBlock Text="OLLAMA 配置" 
                                   Foreground="{StaticResource TextMuted}" 
                                   FontSize="14" 
                                   Margin="0,0,0,20"
                                   FontWeight="SemiBold"/>
                        
                        <!-- Ollama IP地址 -->
                        <TextBlock Text="服务器地址" 
                                   Foreground="{StaticResource TextMuted}" 
                                   FontSize="12" 
                                   Margin="0,0,0,8"/>
                        <TextBox x:Name="OllamaUrlTextBox" 
                                 Text="http://localhost:11434" 
                                 Background="#1a1c26" 
                                 Foreground="{StaticResource Text}" 
                                 Padding="12,10" 
                                 Margin="0,0,0,20"
                                 FontSize="14"
                                 Height="40"/>

                        <!-- 模型选择 -->
                        <TextBlock Text="工具模型" 
                                   Foreground="{StaticResource TextMuted}" 
                                   FontSize="12" 
                                   Margin="0,0,0,8"/>
                        <ComboBox x:Name="ModelComboBox" 
                                  Background="#1a1c26" 
                                  Foreground="Black" 
                                  Padding="12,10" 
                                  Margin="0,0,0,20"
                                  FontSize="14"
                                  Height="40"/>

                        <!-- 视觉模型选择 -->
                        <TextBlock Text="视觉模型 (用于图片识别)" 
                                   Foreground="{StaticResource TextMuted}" 
                                   FontSize="12" 
                                   Margin="0,0,0,8"/>
                        <ComboBox x:Name="VisionModelComboBox" 
                                  Background="#1a1c26" 
                                  Foreground="Black" 
                                  Padding="12,10" 
                                  Margin="0,0,0,8"
                                  FontSize="14"
                                  Height="40">
                        </ComboBox>
                        <TextBlock Text="推荐: llava 或 minicpm-v (需先 ollama pull 拉取)" 
                                   Foreground="{StaticResource TextMuted}" 
                                   FontSize="11" 
                                   Margin="0,0,0,20"/>

                        <!-- 刷新模型按钮 -->
                        <Button x:Name="RefreshModelsBtn"
                                Content="🔄 刷新可用模型" 
                                HorizontalAlignment="Left" 
                                Width="160" 
                                Height="40" 
                                Background="{StaticResource AccentGradient}" 
                                Foreground="{StaticResource Text}" 
                                BorderThickness="0" 
                                Cursor="Hand" 
                                Click="RefreshModelsBtn_Click"
                                FontSize="13"/>
                        
                        <!-- 测试连接按钮 -->
                        <Button x:Name="TestConnectionBtn"
                                Content="🔌 测试连接" 
                                HorizontalAlignment="Left" 
                                Width="160" 
                                Height="40" 
                                Margin="8,0,0,0"
                                Background="Transparent" 
                                Foreground="{StaticResource Text}" 
                                BorderBrush="{StaticResource Border}" 
                                BorderThickness="1" 
                                Cursor="Hand" 
                                Click="TestConnectionBtn_Click"
                                FontSize="13"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            
            <!-- 搜索设置标签页 -->
            <TabItem Header="搜索引擎">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Background="{StaticResource BgCard}">
                        <TextBlock Text="百度千帆搜索配置" 
                                   Foreground="{StaticResource TextMuted}" 
                                   FontSize="14" 
                                   Margin="0,0,0,20"
                                   FontWeight="SemiBold"/>
                        
                        <!-- API密钥 -->
                        <TextBlock Text="API密钥" 
                                   Foreground="{StaticResource TextMuted}" 
                                   FontSize="12" 
                                   Margin="0,0,0,8"/>
                        <PasswordBox x:Name="BaiduApiKeyPasswordBox" 
                                     Background="#1a1c26" 
                                     Foreground="{StaticResource Text}" 
                                     Padding="12,10" 
                                     Margin="0,0,0,20"
                                     FontSize="14"
                                     Height="40"
                                     ToolTip="请输入百度千帆API密钥"/>

                        <!-- 用户ID -->
                        <TextBlock Text="用户ID" 
                                   Foreground="{StaticResource TextMuted}" 
                                   FontSize="12" 
                                   Margin="0,0,0,8"/>
                        <TextBox x:Name="BaiduUserIdTextBox" 
                                 Background="#1a1c26" 
                                 Foreground="{StaticResource Text}" 
                                 Padding="12,10" 
                                 Margin="0,0,0,20"
                                 FontSize="14"
                                 Height="40"
                                 ToolTip="请输入百度千帆用户ID"/>
                                 
                        <TextBlock Text="获取API密钥请访问：https://console.bce.baidu.com/" 
                                   Foreground="{StaticResource TextMuted}" 
                                   FontSize="11" 
                                   TextWrapping="Wrap"
                                   Margin="0,5,0,0"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            
            <!-- 知识库标签页 -->
            <TabItem Header="知识记忆库">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Background="{StaticResource BgCard}">
                        <TextBlock Text="知识库管理" 
                                   Foreground="{StaticResource TextMuted}" 
                                   FontSize="14" 
                                   Margin="0,0,0,20"
                                   FontWeight="SemiBold"/>
                        
                        <TextBlock Text="知识库功能已集成到主界面中，点击侧边栏的“🧠 知识库”按钮即可访问。" 
                                   Foreground="{StaticResource TextMuted}" 
                                   FontSize="13" 
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,16"/>
                                   
                        <Border Background="#1a1c26" 
                                CornerRadius="6"
                                Padding="16"
                                Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="功能特性" 
                                           Foreground="{StaticResource Text}" 
                                           FontSize="13" 
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,12"/>
                                <TextBlock Text="• 支持手动添加知识条目" 
                                           Foreground="{StaticResource TextMuted}" 
                                           FontSize="12" 
                                           Margin="0,0,0,6"/>
                                <TextBlock Text="• 支持导入多种文件格式（TXT, DOCX, PDF, Excel等）" 
                                           Foreground="{StaticResource TextMuted}" 
                                           FontSize="12" 
                                           Margin="0,0,0,6"/>
                                <TextBlock Text="• AI回答问题时会自动参考知识库内容" 
                                           Foreground="{StaticResource TextMuted}" 
                                           FontSize="12" 
                                           Margin="0,0,0,6"/>
                                <TextBlock Text="• 知识库内容永久保存在本地" 
                                           Foreground="{StaticResource TextMuted}" 
                                           FontSize="12" 
                                           Margin="0,0,0,6"/>
                            </StackPanel>
                        </Border>
                                   
                        <TextBlock Text="💡 提示：定期维护知识库可以获得更好的AI回答质量" 
                                   Foreground="{StaticResource Accent}" 
                                   FontSize="12" 
                                   FontStyle="Italic"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            
            <!-- OpenClaw 设置标签页 -->
            <TabItem Header="全能小海">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Background="{StaticResource BgCard}">
                        <TextBlock Text="OpenClaw Agent 配置" 
                                   Foreground="{StaticResource TextMuted}" 
                                   FontSize="14" 
                                   Margin="0,0,0,20"
                                   FontWeight="SemiBold"/>
                        
                        <!-- Gateway 地址 -->
                        <TextBlock Text="OpenClaw WebUI 地址" 
                                   Foreground="{StaticResource TextMuted}" 
                                   FontSize="12" 
                                   Margin="0,0,0,8"/>
                        <TextBox x:Name="OpenClawUrlTextBox" 
                                 Text="http://127.0.0.1:18789" 
                                 Background="#1a1c26" 
                                 Foreground="{StaticResource Text}" 
                                 Padding="12,10" 
                                 Margin="0,0,0,20"
                                 FontSize="14"
                                 Height="40"/>
                                 
                        <TextBlock Text="点击主界面的“🌟 全能小海”按钮将直接在浏览器中打开此地址" 
                                   Foreground="{StaticResource TextMuted}" 
                                   FontSize="11" 
                                   TextWrapping="Wrap"
                                   Margin="0,5,0,0"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            
            <!-- 视觉识别 设置标签页 -->
            <TabItem Header="视觉识别">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Background="{StaticResource BgCard}">
                        <TextBlock Text="智能自动填表" 
                                   Foreground="{StaticResource TextMuted}" 
                                   FontSize="14" 
                                   Margin="0,0,0,20"
                                   FontWeight="SemiBold"/>
                                 
                        <Border Background="#1a1c26" 
                                CornerRadius="6"
                                Padding="16"
                                Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="功能说明" 
                                           Foreground="{StaticResource Text}" 
                                           FontSize="13" 
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,12"/>
                                <TextBlock Text="• OCR识别使用本地视觉大模型（llava）" 
                                           Foreground="{StaticResource TextMuted}" 
                                           FontSize="12" 
                                           Margin="0,0,0,6"/>
                                <TextBlock Text="• 首次使用前请安装视觉模型：ollama pull llava" 
                                           Foreground="{StaticResource TextMuted}" 
                                           FontSize="12" 
                                           Margin="0,0,0,6"/>
                                <TextBlock Text="• AI会自动识别图片中的字段和值" 
                                           Foreground="{StaticResource TextMuted}" 
                                           FontSize="12" 
                                           Margin="0,0,0,6"/>
                                <TextBlock Text="• AI会自动分析网页表单结构" 
                                           Foreground="{StaticResource TextMuted}" 
                                           FontSize="12" 
                                           Margin="0,0,0,6"/>
                                <TextBlock Text="• AI会智能匹配图片字段和表单字段" 
                                           Foreground="{StaticResource TextMuted}" 
                                           FontSize="12" 
                                           Margin="0,0,0,6"/>
                                <TextBlock Text="• 无需手动配置元素定位符" 
                                           Foreground="{StaticResource TextMuted}" 
                                           FontSize="12" 
                                           Margin="0,0,0,6"/>
                            </StackPanel>
                        </Border>
                        
                        <Border Background="#2a2c36" 
                                CornerRadius="6"
                                Padding="16"
                                Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="使用流程" 
                                           Foreground="{StaticResource Text}" 
                                           FontSize="13" 
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,12"/>
                                <TextBlock Text="1. 点击主界面的“🔍 视觉识别”按钮" 
                                           Foreground="{StaticResource TextMuted}" 
                                           FontSize="12" 
                                           Margin="0,0,0,6"/>
                                <TextBlock Text="2. 选择要识别的图片（身份证、表单等）" 
                                           Foreground="{StaticResource TextMuted}" 
                                           FontSize="12" 
                                           Margin="0,0,0,6"/>
                                <TextBlock Text="3. 点击“🔍 识别图片”，AI提取字段信息" 
                                           Foreground="{StaticResource TextMuted}" 
                                           FontSize="12" 
                                           Margin="0,0,0,6"/>
                                <TextBlock Text="4. 输入目标网页URL" 
                                           Foreground="{StaticResource TextMuted}" 
                                           FontSize="12" 
                                           Margin="0,0,0,6"/>
                                <TextBlock Text="5. 点击“✏️ 自动填表”，AI智能填充" 
                                           Foreground="{StaticResource TextMuted}" 
                                           FontSize="12" 
                                           Margin="0,0,0,6"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
        
        <!-- 按钮区域 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="CancelBtn" 
                    Content="取消" 
                    Width="100" 
                    Height="40" 
                    Margin="0,0,12,0" 
                    Background="Transparent" 
                    Foreground="{StaticResource Text}" 
                    BorderThickness="1" 
                    Cursor="Hand" 
                    Click="CancelBtn_Click"
                    FontSize="13"/>
            <Button x:Name="SaveBtn" 
                    Content="💾 保存设置" 
                    Width="120" 
                    Height="40" 
                    Background="{StaticResource AccentGradient}" 
                    Foreground="White" 
                    BorderThickness="0" 
                    Cursor="Hand" 
                    Click="SaveBtn_Click"
                    FontSize="13"/>
        </StackPanel>
    </Grid>
</Window>