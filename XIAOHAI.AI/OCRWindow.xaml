<Window x:Class="XIAOHAI.AI.OCRWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:XIAOHAI.AI"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        mc:Ignorable="d"
        Title="视觉识别与自动填表" Height="800" Width="1200"
        MinHeight="600" MinWidth="900"
        Background="#0a0b0f"
        WindowStartupLocation="CenterOwner"
        Icon="/ziyuan/bitbug_favicon.ico">
    <Window.Resources>
        <SolidColorBrush x:Key="BgDark" Color="#0a0b0f"/>
        <SolidColorBrush x:Key="BgCard" Color="#12141c"/>
        <SolidColorBrush x:Key="Border" Color="#6366f1"/>
        <SolidColorBrush x:Key="Text" Color="#e8eaf0"/>
        <SolidColorBrush x:Key="TextMuted" Color="#8b8fa8"/>
        <SolidColorBrush x:Key="Accent" Color="#6366f1"/>
        <SolidColorBrush x:Key="AccentPurple" Color="#8b5cf6"/>
        <SolidColorBrush x:Key="Success" Color="#22c55e"/>
        <SolidColorBrush x:Key="Warning" Color="#f59e0b"/>
        <LinearGradientBrush x:Key="AccentGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#6366f1" Offset="0"/>
            <GradientStop Color="#8b5cf6" Offset="1"/>
        </LinearGradientBrush>
    </Window.Resources>
    
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="🔍 视觉识别与自动填表" FontSize="22" FontWeight="Bold" Foreground="{StaticResource Text}" Margin="0,0,0,12"/>
            
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBox x:Name="UrlTextBox" Height="36" Padding="12,0" VerticalContentAlignment="Center"
                             Background="Transparent" Foreground="{StaticResource Text}" BorderBrush="{StaticResource Border}" BorderThickness="1"
                             Text="https://szhlzn.top/k3cloud/html5/index.aspx" FontSize="13" Width="350" KeyDown="UrlTextBox_KeyDown"/>
                    <Button x:Name="GoBtn" Content="打开" Width="60" Height="36" Margin="8,0,0,0"
                            Background="{StaticResource Accent}" Foreground="White" BorderThickness="0"
                            Cursor="Hand" Click="GoBtn_Click"/>
                </StackPanel>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="16,0,0,0">
                    <Button x:Name="SelectImageBtn" Content="📁 上传图片" Width="100" Height="36" Margin="0,0,8,0"
                            Background="Transparent" Foreground="{StaticResource Text}" BorderBrush="{StaticResource Border}" BorderThickness="1"
                            Cursor="Hand" Click="SelectImageBtn_Click"/>
                    <TextBlock x:Name="ImageStatusText" Text="未选择图片" Foreground="{StaticResource TextMuted}" FontSize="12" 
                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                </StackPanel>
                
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button x:Name="RecognizeAndFillBtn" Content="🔍 智能识别" Width="100" Height="36" Margin="0,0,8,0"
                            Background="{StaticResource AccentGradient}" Foreground="White" BorderThickness="0"
                            Cursor="Hand" Click="RecognizeAndFillBtn_Click" IsEnabled="False"/>
                    <Button x:Name="ConfirmFillBtn" Content="✅ 确认填写" Width="100" Height="36" Margin="0,0,0,0"
                            Background="#22c55e" Foreground="White" BorderThickness="0"
                            Cursor="Hand" Click="ConfirmFillBtn_Click" IsEnabled="False" Visibility="Collapsed"/>
                </StackPanel>
            </Grid>
            
            <ProgressBar x:Name="ProgressIndicator" Height="3" Margin="0,12,0,0" 
                         Background="{StaticResource BgCard}" Foreground="{StaticResource Accent}"
                         Visibility="Collapsed" IsIndeterminate="True"/>
            
            <Grid Margin="0,12,0,0" Visibility="Collapsed" x:Name="ProgressDetailPanel">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="📊 进度:" Foreground="{StaticResource TextMuted}" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Grid.Column="1" x:Name="ProgressDetailText" Text="准备中..." Foreground="{StaticResource Text}" FontSize="12" VerticalAlignment="Center"/>
            </Grid>
        </StackPanel>
        
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
            
            <Border Grid.Column="0" Background="{StaticResource BgCard}" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <Border Grid.Row="0" Background="#1a1c25" Padding="12,8" CornerRadius="6,6,0,0">
                        <Grid>
                            <TextBlock Text="🌐 内嵌浏览器" Foreground="{StaticResource TextMuted}" FontSize="12" FontWeight="Medium"/>
                            <TextBlock x:Name="WebViewStatusText" Text="" Foreground="{StaticResource Success}" FontSize="11" 
                                       HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    
                    <Grid Grid.Row="1">
                        <wv2:WebView2 x:Name="WebView" Source="about:blank" 
                                      DefaultBackgroundColor="Transparent"
                                      NavigationCompleted="WebView_NavigationCompleted"/>
                    </Grid>
                </Grid>
            </Border>
            
            <GridSplitter Grid.Column="1" Width="8" HorizontalAlignment="Center" VerticalAlignment="Stretch" 
                          Background="Transparent" ShowsPreview="True"/>
            
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <Border Grid.Row="0" Background="{StaticResource BgCard}" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="6" Margin="0,0,0,8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <Border Grid.Row="0" Background="#1a1c25" Padding="12,8" CornerRadius="6,6,0,0">
                            <Grid>
                                <TextBlock Text="🖼️ 图片预览" Foreground="{StaticResource TextMuted}" FontSize="12" FontWeight="Medium"/>
                                <Button x:Name="ZoomInBtn" Content="➕" HorizontalAlignment="Right" Margin="0,0,60,0"
                                        Background="Transparent" Foreground="{StaticResource TextMuted}" 
                                        BorderThickness="0" FontSize="12" Padding="6,2" Cursor="Hand" Click="ZoomInBtn_Click"/>
                                <Button x:Name="ZoomOutBtn" Content="➖" HorizontalAlignment="Right" Margin="0,0,30,0"
                                        Background="Transparent" Foreground="{StaticResource TextMuted}" 
                                        BorderThickness="0" FontSize="12" Padding="6,2" Cursor="Hand" Click="ZoomOutBtn_Click"/>
                                <Button x:Name="ResetZoomBtn" Content="🔄" HorizontalAlignment="Right"
                                        Background="Transparent" Foreground="{StaticResource TextMuted}" 
                                        BorderThickness="0" FontSize="12" Padding="6,2" Cursor="Hand" Click="ResetZoomBtn_Click"/>
                            </Grid>
                        </Border>
                        
                        <Border Grid.Row="1" Background="#0a0b0f" Padding="8" CornerRadius="0,0,6,6" Height="200">
                            <ScrollViewer x:Name="ImagePreviewScroll" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                                <Grid x:Name="ImagePreviewContainer" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Image x:Name="ImagePreview" Source="{x:Null}" Stretch="Uniform" MaxWidth="300" MaxHeight="180"
                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Grid>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Border>
                
                <Border Grid.Row="1" Background="{StaticResource BgCard}" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="6" Margin="0,0,0,8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <Border Grid.Row="0" Background="#1a1c25" Padding="12,8" CornerRadius="6,6,0,0">
                            <Grid>
                                <TextBlock Text="📋 识别结果" Foreground="{StaticResource TextMuted}" FontSize="12" FontWeight="Medium"/>
                                <Button x:Name="ClearResultsBtn" Content="清空" HorizontalAlignment="Right" 
                                        Background="Transparent" Foreground="{StaticResource TextMuted}" 
                                        BorderThickness="1" BorderBrush="{StaticResource Border}"
                                        FontSize="11" Padding="8,4" Cursor="Hand" Click="ClearResultsBtn_Click"/>
                            </Grid>
                        </Border>
                        
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="ExtractedFieldsList" Padding="12">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#1a1c25" CornerRadius="4" Padding="10,8" Margin="0,0,0,6">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Label}" Foreground="{StaticResource TextMuted}" FontSize="12" 
                                                           VerticalAlignment="Center" Margin="0,0,12,0" MinWidth="60"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Value}" Foreground="{StaticResource Text}" FontSize="13" 
                                                           VerticalAlignment="Center" TextWrapping="Wrap"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
                
                <Border Grid.Row="2" Background="{StaticResource BgCard}" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="6">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <Border Grid.Row="0" Background="#1a1c25" Padding="12,8" CornerRadius="6,6,0,0">
                            <TextBlock Text="📝 操作日志" Foreground="{StaticResource TextMuted}" FontSize="12" FontWeight="Medium"/>
                        </Border>
                        
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <TextBox x:Name="LogTextBox" 
                                     Background="Transparent" 
                                     Foreground="{StaticResource Text}" 
                                     BorderThickness="0" 
                                     Padding="12"
                                     FontSize="12"
                                     TextWrapping="Wrap"
                                     IsReadOnly="True"
                                     VerticalAlignment="Stretch"
                                     HorizontalAlignment="Stretch"
                                     VerticalContentAlignment="Top"/>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
        
        <Border Grid.Row="2" Background="#1a1c25" CornerRadius="6" Padding="12,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Border x:Name="Step1Indicator" Background="#374151" CornerRadius="4" Padding="10,6" Margin="0,0,8,0">
                        <TextBlock Text="① 打开网站" Foreground="{StaticResource TextMuted}" FontSize="12"/>
                    </Border>
                    <Border x:Name="Step2Indicator" Background="#374151" CornerRadius="4" Padding="10,6" Margin="0,0,8,0">
                        <TextBlock Text="② 上传图片" Foreground="{StaticResource TextMuted}" FontSize="12"/>
                    </Border>
                    <Border x:Name="Step3Indicator" Background="#374151" CornerRadius="4" Padding="10,6" Margin="0,0,8,0">
                        <TextBlock Text="③ 智能识别" Foreground="{StaticResource TextMuted}" FontSize="12"/>
                    </Border>
                    <Border x:Name="Step4Indicator" Background="#374151" CornerRadius="4" Padding="10,6">
                        <TextBlock Text="④ 确认填写" Foreground="{StaticResource TextMuted}" FontSize="12"/>
                    </Border>
                </StackPanel>
                
                <TextBlock Grid.Column="1" x:Name="StatusText" Text="请先打开需要填写的网站" 
                           Foreground="{StaticResource TextMuted}" FontSize="12" 
                           VerticalAlignment="Center" HorizontalAlignment="Center"/>
                
                <TextBlock Grid.Column="2" Text="💡 填写后请在浏览器中确认并提交" 
                           Foreground="{StaticResource TextMuted}" FontSize="12" 
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
