<Window x:Class="XIAOHAI.AI.AutomationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="小海 · 自动化助手"
        Height="800" Width="1400"
        MinHeight="600" MinWidth="1000"
        Background="#0a0b0f"
        WindowStartupLocation="CenterScreen"
        Icon="/ziyuan/bitbug_favicon.ico">
    
    <Window.Resources>
        <SolidColorBrush x:Key="BgDark" Color="#0a0b0f"/>
        <SolidColorBrush x:Key="BgCard" Color="#12141c"/>
        <SolidColorBrush x:Key="Border" Color="#6366f1"/>
        <SolidColorBrush x:Key="Text" Color="#e8eaf0"/>
        <SolidColorBrush x:Key="TextMuted" Color="#8b8fa8"/>
        <SolidColorBrush x:Key="Accent" Color="#6366f1"/>
        <SolidColorBrush x:Key="Success" Color="#10b981"/>
        <SolidColorBrush x:Key="Warning" Color="#f59e0b"/>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- 标题栏 -->
        <Border Grid.Row="0" Background="{StaticResource BgCard}" BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1" Padding="20,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="🤖" FontSize="24" Foreground="White" Margin="0,0,12,0" VerticalAlignment="Center"/>
                    <StackPanel>
                        <TextBlock Text="自动化助手" Foreground="{StaticResource Text}" FontWeight="SemiBold" FontSize="18"/>
                        <TextBlock x:Name="StatusText" Text="就绪" Foreground="{StaticResource TextMuted}" FontSize="12"/>
                    </StackPanel>
                </StackPanel>
                
                <Button x:Name="CloseBtn" Grid.Column="1" Content="✕" Width="32" Height="32"
                        Background="Transparent" Foreground="{StaticResource TextMuted}" BorderThickness="0"
                        Cursor="Hand" Click="CloseBtn_Click" FontSize="16">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="#ef4444"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>
        
        <!-- 主内容区 - 三栏布局 -->
        <Grid Grid.Row="1" Margin="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="400"/>
            </Grid.ColumnDefinitions>
            
            <!-- 左侧：技能列表 -->
            <Border Grid.Column="0" Background="{StaticResource BgCard}" BorderBrush="{StaticResource Border}" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- 技能列表标题 -->
                    <Border Grid.Row="0" Background="{StaticResource Border}" Padding="12,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="📚 我的技能库" Foreground="{StaticResource Text}" FontWeight="SemiBold" FontSize="13"/>
                            <TextBlock x:Name="SkillCountText" Grid.Column="1" Text="0 个技能" Foreground="{StaticResource Text}" FontSize="12" Margin="0,0,8,0"/>
                        </Grid>
                    </Border>
                    
                    <!-- 技能列表 -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="SkillListPanel">
                            <!-- 技能项模板 -->
                            <Border Background="#1a1c25" BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1" Padding="12" Margin="0">
                                <StackPanel>
                                    <TextBlock Text="📝 示例技能" Foreground="{StaticResource Text}" FontWeight="SemiBold" FontSize="13"/>
                                    <TextBlock Text="打开记事本并输入文本" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                    <TextBlock Text="最后使用：2024-01-01" Foreground="{StaticResource TextMuted}" FontSize="10" Margin="0,4,0,0"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                        <Button Content="▶ 执行" Width="55" Height="24" Margin="0,0,4,0" FontSize="11"
                                                Background="{StaticResource Success}" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                                        <Button Content="✏ 编辑" Width="55" Height="24" Margin="0,0,4,0" FontSize="11"
                                                Background="{StaticResource Warning}" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                                        <Button Content="📝 重命名" Width="65" Height="24" Margin="0,0,4,0" FontSize="11"
                                                Background="{StaticResource Accent}" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                                        <Button Content="🗑 删除" Width="55" Height="24" FontSize="11"
                                                Background="#ef4444" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
            
            <!-- 中间：聊天对话区 -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- 聊天消息区 -->
                <ScrollViewer x:Name="MessageScroll" Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="20" Background="Transparent">
                    <StackPanel x:Name="MessagePanel">
                        <!-- 欢迎消息 -->
                        <Border Background="{StaticResource BgCard}" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,12" HorizontalAlignment="Left" MaxWidth="600">
                            <StackPanel>
                                <TextBlock Text="👋 你好！我是自动化助手" Foreground="{StaticResource Accent}" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8"/>
                                <TextBlock Text="我可以帮你完成各种桌面自动化任务，例如：" Foreground="{StaticResource Text}" FontSize="13" Margin="0,0,0,8" TextWrapping="Wrap"/>
                                <TextBlock Text="• 打开软件并执行操作" Foreground="{StaticResource TextMuted}" FontSize="12" Margin="8,0,0,4"/>
                                <TextBlock Text="• 自动填写表单" Foreground="{StaticResource TextMuted}" FontSize="12" Margin="8,0,0,4"/>
                                <TextBlock Text="• 批量处理文件" Foreground="{StaticResource TextMuted}" FontSize="12" Margin="8,0,0,4"/>
                                <TextBlock Text="• 浏览器自动化操作" Foreground="{StaticResource TextMuted}" FontSize="12" Margin="8,0,0,8"/>
                                <TextBlock Text="请直接告诉我你想要完成的任务吧！" Foreground="{StaticResource Text}" FontSize="13" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
                
                <!-- 输入区 -->
                <Border Grid.Row="1" Background="{StaticResource BgCard}" BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0" Padding="20,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBox x:Name="InputBox" Grid.Column="0" Height="48" Padding="12,10"
                                 Background="#1a1c25" Foreground="{StaticResource Text}" CaretBrush="{StaticResource Accent}"
                                 BorderBrush="{StaticResource Border}" BorderThickness="1" FontSize="14"
                                 AcceptsReturn="True" VerticalContentAlignment="Center"
                                 KeyDown="InputBox_KeyDown">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="TextBox">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="8">
                                                    <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                        
                        <Button x:Name="SendBtn" Grid.Column="1" Width="80" Height="48" Margin="12,0,0,0"
                                Background="{StaticResource Accent}" Foreground="White" BorderThickness="0"
                                Cursor="Hand" Click="SendBtn_Click" Content="发送">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="8">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#8b5cf6"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Background" Value="#4a4a5a"/>
                                            <Setter Property="Foreground" Value="#8b8fa8"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </Border>
            </Grid>
            
            <!-- 右侧：详细执行日志 -->
            <Border Grid.Column="2" Background="{StaticResource BgCard}" BorderBrush="{StaticResource Border}" BorderThickness="1,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- 日志标题 -->
                    <Border Grid.Row="0" Background="#1e1f29" Padding="12,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="📋 执行日志" Foreground="{StaticResource Text}" FontWeight="SemiBold" FontSize="13"/>
                            <Button x:Name="ClearLogBtn" Grid.Column="1" Content="清空" Width="50" Height="24" Margin="0,0,8,0"
                                    Background="Transparent" Foreground="{StaticResource TextMuted}" BorderBrush="{StaticResource TextMuted}" 
                                    BorderThickness="1" Cursor="Hand" Click="ClearLogBtn_Click" FontSize="11"/>
                        </Grid>
                    </Border>
                    
                    <!-- 日志内容 -->
                    <ScrollViewer x:Name="LogScroll" Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="8">
                        <StackPanel x:Name="LogPanel">
                            <!-- 日志项会通过代码动态添加 -->
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
