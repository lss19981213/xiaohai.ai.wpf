<Window x:Class="XIAOHAI.AI.AnswerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="小海 · 智能解答"
        Height="400" Width="500"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual">
    
    <Window.Resources>
        <SolidColorBrush x:Key="BgDark" Color="#12141c"/>
        <SolidColorBrush x:Key="Border" Color="#6366f1"/>
        <SolidColorBrush x:Key="Text" Color="#e8eaf0"/>
        <SolidColorBrush x:Key="TextMuted" Color="#8b8fa8"/>
        <SolidColorBrush x:Key="Accent" Color="#6366f1"/>
    </Window.Resources>
    
    <Border Background="{StaticResource BgDark}" 
            BorderBrush="{StaticResource Border}" 
            BorderThickness="1" 
            CornerRadius="12">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.5" Color="#6366f1"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- 标题栏 -->
            <Grid Grid.Row="0" Background="{StaticResource Border}" Height="36">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                    <TextBlock Text="💡" FontSize="16" Margin="0,0,8,0"/>
                    <TextBlock Text="小海 · 智能解答" Foreground="{StaticResource Text}" 
                               FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                </StackPanel>
                
                <!-- 关闭按钮 -->
                <Button Grid.Column="1" Content="✕" Width="36" Height="36"
                        Background="Transparent" Foreground="{StaticResource Text}"
                        BorderThickness="0" FontSize="16" Cursor="Hand"
                        Click="CloseBtn_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" 
                                    BorderBrush="{TemplateBinding BorderBrush}" 
                                    BorderThickness="{TemplateBinding BorderThickness}" 
                                    CornerRadius="0,12,0,0">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#ef4444"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
            
            <!-- 内容区域 -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" 
                          Padding="16" Background="Transparent">
                <StackPanel>
                    <!-- 加载状态 -->
                    <StackPanel x:Name="LoadingPanel" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,40,0,0">
                        <TextBlock Text="🔍 正在分析屏幕内容..." FontSize="16" Foreground="{StaticResource Text}"
                                   HorizontalAlignment="Center" Margin="0,0,0,12"/>
                        <TextBlock x:Name="LoadingText" Text="请稍候..." FontSize="12" Foreground="{StaticResource TextMuted}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                    
                    <!-- 回答内容 -->
                    <StackPanel x:Name="AnswerPanel" Visibility="Collapsed">
                        <Border Background="#1e1f29" BorderBrush="{StaticResource Border}" 
                                BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="📌 识别到的问题" FontSize="13" Foreground="{StaticResource Accent}" 
                                           FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <TextBlock x:Name="QuestionText" Text="" FontSize="12" Foreground="{StaticResource Text}"
                                           TextWrapping="Wrap" LineHeight="18"/>
                            </StackPanel>
                        </Border>
                        
                        <Border Background="#1e1f29" BorderBrush="{StaticResource Border}" 
                                BorderThickness="1" CornerRadius="8" Padding="12">
                            <StackPanel>
                                <TextBlock Text="💬 AI 解答" FontSize="13" Foreground="#10b981" 
                                           FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <TextBlock x:Name="AnswerText" Text="" FontSize="12" Foreground="{StaticResource Text}"
                                           TextWrapping="Wrap" LineHeight="18"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    
                    <!-- 错误信息 -->
                    <StackPanel x:Name="ErrorPanel" Visibility="Collapsed" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,40,0,0">
                        <TextBlock Text="❌ 分析失败" FontSize="16" Foreground="#ef4444"
                                   HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock x:Name="ErrorText" Text="" FontSize="12" Foreground="{StaticResource TextMuted}"
                                   HorizontalAlignment="Center" TextWrapping="Wrap"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
